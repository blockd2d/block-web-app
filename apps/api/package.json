{
  "name": "@block/api",
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json --outDir dist",
    "start": "node dist/index.js",
    "worker:dev": "tsx watch src/worker.ts",
    "worker": "node dist/worker.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "seed:dev": "tsx src/scripts/seed-dev.ts"
  },
  "dependencies": {
    "@blockd2d/shared": "^0.1.1",
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/formbody": "^8.0.1",
    "@fastify/rate-limit": "^9.0.0",
    "@prisma/client": "^7.2.0",
    "@supabase/supabase-js": "^2.45.4",
    "csv-stringify": "^6.5.1",
    "fastify": "^4.28.1",
    "pdfkit": "^0.15.0",
    "pino": "^9.3.2",
    "posthog-node": "^4.2.0",
    "stripe": "^16.10.0",
    "twilio": "^5.3.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pdfkit": "^0.13.9",
    "prisma": "^7.2.0",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4"
  }
}