# Block API (Railway / Local)
NODE_ENV=development
PORT=4000

# === Supabase ===
# Use REST URL (not Postgres URL). Supabase JS client requires: https://PROJECT_REF.supabase.co
SUPABASE_URL=***
SUPABASE_ANON_KEY=***
SUPABASE_SERVICE_ROLE_KEY=***

# === Auth cookies (web session) ===
# Use a root domain in production (e.g. "yourdomain.com"). For local dev: localhost
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
SESSION_COOKIE_NAME=block_session
REFRESH_COOKIE_NAME=block_refresh
CSRF_COOKIE_NAME=block_csrf
WEB_BASE_URL=http://localhost:3000

# === Cloudflare Turnstile (optional) ===
TURNSTILE_SITE_KEY=***
TURNSTILE_SECRET_KEY=***
# Mobile bypass is useful for local dev; disable in production if you require Turnstile for mobile too
MOBILE_TURNSTILE_BYPASS=true

# === Feature flags ===
# Allow managers/admins to send SMS from the web UI (intervene). Recommended: false until Twilio is configured.
FEATURE_MESSAGES_INTERVENE=false

# === PostHog (optional but recommended) ===
POSTHOG_API_KEY=***
POSTHOG_HOST=https://app.posthog.com

# === Twilio (optional) ===
TWILIO_ACCOUNT_SID=***
TWILIO_AUTH_TOKEN=***
TWILIO_NUMBER=***

# === Stripe (optional) ===
STRIPE_SECRET_KEY=***
STRIPE_WEBHOOK_SECRET=***

# === Public URLs ===
PUBLIC_WEB_URL=http://localhost:3000
