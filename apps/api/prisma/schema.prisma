/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model daily_stats {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id        String        @db.Uuid
  profile_id    String?       @db.Uuid
  rep_id        String?       @db.Uuid
  day           DateTime      @db.Date
  doors_knocked Int           @default(0)
  talked        Int           @default(0)
  leads         Int           @default(0)
  quotes        Int           @default(0)
  sold          Int           @default(0)
  revenue       Decimal       @default(0) @db.Decimal
  xp            Int           @default(0)
  created_at    DateTime      @default(now()) @db.Timestamptz(6)
  updated_at    DateTime      @default(now()) @db.Timestamptz(6)
  hours_worked  Decimal       @default(0) @db.Decimal
  organizations organizations @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles      profiles?     @relation(fields: [profile_id], references: [id], onUpdate: NoAction)
  reps          reps?         @relation(fields: [rep_id], references: [id], onUpdate: NoAction)

  @@unique([org_id, rep_id, day])
  @@index([org_id, day], map: "daily_stats_org_day_idx")
  @@index([org_id, rep_id, day], map: "daily_stats_org_rep_day_idx")
  @@index([rep_id, day], map: "daily_stats_rep_day_idx")
}

