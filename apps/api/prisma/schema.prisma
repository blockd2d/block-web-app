//npm prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model audit_log {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id           String        @db.Uuid
  actor_profile_id String?       @db.Uuid
  action           String
  entity_type      String?
  entity_id        String?       @db.Uuid
  meta_json        Json          @default("{}")
  created_at       DateTime      @default(now()) @db.Timestamptz(6)
  profiles         profiles?     @relation(fields: [actor_profile_id], references: [id], onUpdate: NoAction)
  organizations    organizations @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model cluster_properties {
  org_id        String        @db.Uuid
  cluster_id    String        @db.Uuid
  property_id   String        @db.Uuid
  clusters      clusters      @relation(fields: [cluster_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organizations organizations @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  properties    properties    @relation(fields: [property_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([org_id, cluster_id, property_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model cluster_sets {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id        String        @db.Uuid
  county_id     String        @db.Uuid
  filters_json  Json
  status        String        @default("queued")
  progress      Int           @default(0)
  error         String?
  created_by    String?       @db.Uuid
  created_at    DateTime      @default(now()) @db.Timestamptz(6)
  name          String        @default("Cluster Set")
  radius_m      Int?
  min_houses    Int?
  counties      counties      @relation(fields: [county_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles      profiles?     @relation(fields: [created_by], references: [id], onUpdate: NoAction)
  organizations organizations @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  clusters      clusters[]

  @@index([org_id], map: "cluster_sets_org_idx")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model clusters {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id             String               @db.Uuid
  cluster_set_id     String               @db.Uuid
  name               String?
  center_lat         Float
  center_lng         Float
  hull_geojson       Json
  stats_json         Json                 @default("{}")
  assigned_rep_id    String?              @db.Uuid
  color              String?
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  cluster_properties cluster_properties[]
  reps               reps?                @relation(fields: [assigned_rep_id], references: [id], onUpdate: NoAction)
  cluster_sets       cluster_sets         @relation(fields: [cluster_set_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organizations      organizations        @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([assigned_rep_id], map: "clusters_assigned_rep_idx")
  @@index([org_id, cluster_set_id], map: "clusters_org_set_idx")
}

