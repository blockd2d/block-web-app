{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "base": {
      "env": {
        "EXPO_PACKAGE_MANAGER": "pnpm"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "extends": "base",
      "autoIncrement": true
    }
  }
}
