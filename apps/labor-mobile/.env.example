# =============================================================================
# New Labor Mobile — Environment variables
# Copy this file to .env and fill in the values.
# =============================================================================

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# Block API base URL (auth, jobs, labor, photos, push token). No trailing slash.
EXPO_PUBLIC_API_URL=http://localhost:4000

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------

# Mapbox access token for embedded job maps. Omit to hide or disable map.
# EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your_mapbox_token

# EAS project ID for Expo push notifications. If set, push token uses this.
# EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id
