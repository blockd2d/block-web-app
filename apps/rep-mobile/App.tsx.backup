import "react-native-gesture-handler";

import React, { useEffect, useMemo, useRef } from "react";
import { AppState, AppStateStatus, Platform, View } from "react-native";
import { NavigationContainer } from "@react-navigation/native";
import { QueryClient, QueryClientProvider } from "@tanstack/react-query";
import { StatusBar } from "expo-status-bar";
import * as Network from "expo-network";
import { GestureHandlerRootView } from "react-native-gesture-handler";
import { SafeAreaProvider } from "react-native-safe-area-context";

import { RootNavigator } from "./src/navigation";
import { useQueueStore, useSessionStore, useUIStore } from "./src/state";
import { setUnauthorizedHandler } from "./src/lib/api";
import { theme } from "./src/theme";

function createQueryClient() {
  return new QueryClient({
    defaultOptions: {
      queries: {
        retry: (failureCount, error) => {
          const msg = (error as Error)?.message ?? "";
          if (msg.includes("401")) return false;
          return failureCount < 2;
        },
        staleTime: 20_000
      }
    }
  });
}

export default function App() {
  const queryClient = useMemo(() => createQueryClient(), []);
  const bootstrap = useSessionStore((s) => s.bootstrap);
  const logout = useSessionStore((s) => s.logout);

  const setIsActive = useUIStore((s) => s.setIsActive);
  const setIsOnline = useUIStore((s) => s.setIsOnline);
  const flushQueue = useQueueStore((s) => s.flush);
  const queueCount = useQueueStore((s) => s.items.length);
  const sessionStatus = useSessionStore((s) => s.status);

  const appState = useRef<AppStateStatus>(AppState.currentState);

  useEffect(() => {
    setUnauthorizedHandler(async () => {
      await logout("Your session expired. Please log in again.");
      queryClient.clear();
    });
  }, [logout, queryClient]);

  useEffect(() => {
    bootstrap().catch((e) => {
      console.error("[boot] bootstrap failed", (e as Error)?.message ?? e);
    });
  }, [bootstrap]);

  useEffect(() => {
    const sub = AppState.addEventListener("change", async (nextState) => {
      const prev = appState.current;
      appState.current = nextState;

      if (prev.match(/inactive|background/) && nextState === "active") {
        setIsActive(true);
        flushQueue("app_active").catch(() => {});
      } else if (nextState !== "active") {
        setIsActive(false);
      }
    });

    return () => sub.remove();
  }, [flushQueue, setIsActive]);


  useEffect(() => {
    const timer = setInterval(() => {
      const ui = useUIStore.getState();
      const session = useSessionStore.getState();
      const queue = useQueueStore.getState();
      if (ui.isActive && ui.isOnline && session.status === "authenticated" && queue.items.length > 0 && !queue.flushing) {
        queue.flush("periodic").catch(() => {});
      }
    }, 30_000);

    return () => clearInterval(timer);
  }, []);

  useEffect(() => {
    if (sessionStatus === "authenticated" && queueCount > 0) {
      flushQueue("app_active").catch(() => {});
    }
  }, [flushQueue, queueCount, sessionStatus]);

  useEffect(() => {
    const attach = async () => {
      const state = await Network.getNetworkStateAsync();
      setIsOnline(!!state.isConnected && !!state.isInternetReachable);

      const listener = Network.addNetworkStateListener((s) => {
        const online = !!s.isConnected && !!s.isInternetReachable;
        setIsOnline(online);
        if (online) flushQueue("network_online").catch(() => {});
      });

      return () => listener.remove();
    };

    let cleanup: null | (() => void) = null;
    attach()
      .then((fn) => {
        cleanup = fn;
      })
      .catch(() => {});

    return () => {
      cleanup?.();
    };
  }, [flushQueue, setIsOnline]);

  return (
    <GestureHandlerRootView style={{ flex: 1, backgroundColor: theme.colors.bg }}>
      <SafeAreaProvider>
        <QueryClientProvider client={queryClient}>
          <View style={{ flex: 1, backgroundColor: theme.colors.bg }}>
            <NavigationContainer>
              <RootNavigator />
            </NavigationContainer>
            <StatusBar style={Platform.OS === "ios" ? "dark" : "dark"} />
          </View>
        </QueryClientProvider>
      </SafeAreaProvider>
    </GestureHandlerRootView>
  );
}
