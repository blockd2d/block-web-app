# Nova Sales Mobile (rep-mobile)
# Copy this file to apps/rep-mobile/.env for local development.
# Expo only exposes EXPO_PUBLIC_* variables to the app runtime.

# Default to true so the app runs immediately without a backend.
EXPO_PUBLIC_SALES_MOCK_MODE="true"

# Required when EXPO_PUBLIC_SALES_MOCK_MODE=false (Block API URL)
EXPO_PUBLIC_API_URL="http://localhost:4000"

# Required for the real in-app Mapbox map. Use your public token (starts with pk.).
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN="pk.YOUR_PUBLIC_MAPBOX_TOKEN"

# Optional override; defaults to Streets.
EXPO_PUBLIC_MAPBOX_STYLE_URL="mapbox://styles/mapbox/streets-v12"

# Native Mapbox builds may also require a secret MAPBOX_DOWNLOADS_TOKEN in your shell/EAS env.
# That token is NOT EXPO_PUBLIC_* and should not be committed to source control.
