{
  "name": "block-v7",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo run dev --parallel --filter=@block/api --filter=@block/web",
    "build": "turbo run build --filter=@block/api --filter=@block/web",
    "lint": "turbo run lint --filter=@block/api --filter=@block/web",
    "typecheck": "turbo run typecheck --filter=@block/shared --filter=@block/api --filter=@block/web",
    "format": "prettier -w .",
    "zip": "node scripts/zip-repo.mjs"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.2.3",
    "typescript": "^5.5.4"
  }
}
