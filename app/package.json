{
  "name": "block-v7",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "pnpm -r format",
    "supabase:apply": "supabase db reset --linked || supabase db reset",
    "supabase:migrate": "supabase migration up",
    "supabase:seed": "psql \"$SUPABASE_DB_URL\" -f supabase/seed.sql",
    "api:dev": "pnpm --filter @block/api dev",
    "web:dev": "pnpm --filter @block/manager-web dev",
    "labor:dev": "pnpm --filter @block/labor-mobile dev"
  }
}