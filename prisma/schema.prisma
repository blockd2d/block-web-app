/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model sales {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id           String             @db.Uuid
  rep_id           String             @db.Uuid
  property_id      String             @db.Uuid
  price            Decimal?           @db.Decimal
  service_type     String?
  notes            String?
  customer_phone   String?
  customer_email   String?
  status           String             @default("lead")
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  customer_name    String?
  updated_at       DateTime           @default(now()) @db.Timestamptz(6)
  contracts        contracts?
  jobs             jobs[]
  sale_attachments sale_attachments[]
  organizations    organizations      @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  properties       properties         @relation(fields: [property_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  reps             reps               @relation(fields: [rep_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([org_id, created_at(sort: Desc)], map: "idx_sales_org_created_at")
  @@index([org_id, customer_email], map: "idx_sales_org_customer_email")
  @@index([org_id, customer_name], map: "idx_sales_org_customer_name")
  @@index([org_id, customer_phone], map: "idx_sales_org_customer_phone")
  @@index([org_id, rep_id, created_at(sort: Desc)], map: "idx_sales_org_rep_created_at")
  @@index([org_id, status, created_at(sort: Desc)], map: "idx_sales_org_status_created_at")
  @@index([org_id, rep_id], map: "sales_org_rep_idx")
}
