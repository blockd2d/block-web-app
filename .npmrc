@blockd2d:registry=https://npm.pkg.github.com
always-auth=true

# Hoist Next and React so the web app uses a single copy (avoids webpack "reading 'call' of undefined").
public-hoist-pattern[]=*next*
public-hoist-pattern[]=*react*
public-hoist-pattern[]=*react-dom*
